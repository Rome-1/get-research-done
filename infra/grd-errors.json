{
  "name": "grd-errors",
  "description": "LLM error catalog and traceability matrix for GRD verification. Domain-specific error classes with detection strategies mapped to verification check categories.",
  "transport": "stdio",
  "command": "grd-mcp-errors",
  "args": [],
  "env": {
    "LOG_LEVEL": "${LOG_LEVEL:-WARNING}"
  },
  "capabilities": [
    "get_error_class",
    "check_error_classes",
    "get_detection_strategy",
    "get_traceability",
    "list_error_classes"
  ],
  "registry_prefix": "grd_errors",
  "prerequisites": [
    "Install GRD first: npx -y get-research-done"
  ],
  "health_check": {
    "tool": "list_error_classes",
    "input": {},
    "expect": "count >= 100 error classes loaded"
  },
  "alternatives": {
    "python_module": {
      "command": "python3",
      "args": [
        "-m",
        "grd.mcp.servers.errors_mcp"
      ],
      "notes": "Requires grd package installed"
    }
  }
}
