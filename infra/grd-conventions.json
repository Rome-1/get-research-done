{
  "name": "grd-conventions",
  "description": "GRD convention lock management. Tools for querying, setting, validating, and comparing physics conventions across research phases.",
  "transport": "stdio",
  "command": "grd-mcp-conventions",
  "args": [],
  "env": {
    "LOG_LEVEL": "${LOG_LEVEL:-WARNING}"
  },
  "capabilities": [
    "convention_lock_status",
    "convention_set",
    "convention_check",
    "convention_diff",
    "assert_convention_validate",
    "subfield_defaults"
  ],
  "registry_prefix": "grd_conventions",
  "prerequisites": [
    "Install GRD first: npx -y get-research-done"
  ],
  "health_check": {
    "tool": "convention_lock_status",
    "input": {
      "project_dir": "."
    },
    "expect": "contains set_count"
  },
  "alternatives": {
    "python_module": {
      "command": "python",
      "args": [
        "-m",
        "grd.mcp.servers.conventions_server"
      ],
      "notes": "Requires grd package installed"
    }
  }
}
